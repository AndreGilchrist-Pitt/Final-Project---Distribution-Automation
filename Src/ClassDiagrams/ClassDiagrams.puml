@startuml
title Utils Classes (Power system model + NR power flow + Fault Analysis)

class Settings {
  +freq : float
  +sbase : float
  --
  +__init__(freq: float = 60.0, sbase: float = 100.0)
  +__repr__()
}

class Bus {
  -{static} _bus_counter : int
  -{static} _bus_registry : dict
  -{static} _valid_bus_types : dict
  +name : str
  +nominal_kv : float
  +bus_index : int
  +vpu : float
  +delta : float
  +bus_type : str
  --
  +__init__(name: str, nominal_kv: float, vpu: float = 1.0, delta: float = 0.0, bus_type: str = None)
  +{static} get_bus_index(name: str)
  -{static} _validate_bus_type(bus_type: str) : str
}

class Generator {
  +name : str
  +bus1_name : str
  +voltage_setpoint : float
  +mw_setpoint : float
  +x_subtransient : float
  +p : float
  --
  +__init__(name: str, bus1_name: str, voltage_setpoint: float, mw_setpoint: float, x_subtransient: float = 0.0)
  +calc_p() : float
  +__repr__()
}

class Load {
  +name : str
  +bus1_name : str
  +mw : float
  +mvar : float
  +p : float
  +q : float
  --
  +__init__(name: str, bus1_name: str, mw: float, mvar: float)
  +calc_p() : float
  +calc_q() : float
  +__repr__()
}

class Transformer {
  +name : str
  +bus1_name : str
  +bus2_name : str
  +r : float
  +x : float
  -_yseries : complex
  +Yseries : complex <<property>>
  --
  +__init__(name: str, bus1_name: str, bus2_name: str, r: float, x: float)
  -_calc_Yseries() : complex
  +calc_yprim() : pd.DataFrame
  +__repr__()
}

class TransmissionLine {
  +name : str
  +bus1_name : str
  +bus2_name : str
  +r : float
  +x : float
  +g : float
  +b : float
  -_yseries : complex
  -_yshunt : complex
  +Yseries : complex <<property>>
  +Yshunt : complex <<property>>
  --
  +__init__(name: str, bus1_name: str, bus2_name: str, r: float, x: float, g: float, b: float)
  -_calc_Yseries() : complex
  -_calc_Yshunt() : complex
  +calc_yprim() : pd.DataFrame
  +__repr__()
}

class Circuit {
  +name : str
  +buses : dict
  +transformers : dict
  +transmission_lines : dict
  +generators : dict
  +loads : dict
  +ybus : ndarray
  +solver : Solver
  +voltage_vector_polar : list <<property>>
  +voltage_vector_rectangular : ndarray <<property>>
  --
  +__init__(name: str)
  +add_bus(name, nominal_kv, vpu=1.0, delta=0.0, bus_type=None)
  +add_transformer(name, bus1_name, bus2_name, r, x)
  +add_transmission_line(name, bus1_name, bus2_name, r, x, g, b)
  +add_generator(name, bus1_name, voltage_setpoint, mw_setpoint, x_subtransient=0.0)
  +add_load(name, bus1_name, mw, mvar)
  +calc_ybus() : void
  +calc_ybus_fault() : ndarray
  +calc_zbus(ybus_fault) : ndarray
  +calc_fault_current(zbus, faulted_bus_name, prefault_voltage=1.0) : complex
  +calc_fault_voltages(zbus, faulted_bus_name, prefault_voltage=1.0) : dict
  +bus_angles() : ndarray
  +bus_voltages() : ndarray
  -_real_power_injection(bus, ybus, voltages) : float
  -_reactive_power_injection(bus, ybus, voltages) : float
  +compute_power_injection(bus, ybus, voltages) : (float, float)
  +compute_power_mismatch(buses, ybus, voltages) : ndarray
  +solve(mode="power_flow", tol=1e-4, max_iter=50, faulted_bus_name=None, prefault_voltage=1.0, verbose=False) : Solver
}

class Jacobian {
  +J : ndarray
  --
  +__init__()
  -_non_slack_buses(buses) : list
  -_pq_buses(buses) : list
  +NON_SLACK_BUSES(buses) : list
  +PQ_BUSES(buses) : list
  -_power_injections(ybus, angles, voltages) : (ndarray, ndarray)
  -_build_j1(ybus, angles, voltages, p_buses) : ndarray
  -_build_j2(ybus, angles, voltages, p_buses, pq_buses) : ndarray
  -_build_j3(ybus, angles, voltages, pq_buses, p_buses) : ndarray
  -_build_j4(ybus, angles, voltages, pq_buses) : ndarray
  +calculate_jacobian(buses, ybus, angles, voltages) : ndarray
}

class PowerFlow {
  -_jac : Jacobian
  +iterations : int
  +converged : bool
  +final_mismatch_max : float
  --
  +__init__()
  +{static} _non_slack_buses(buses) : list
  +{static} _pq_buses(buses) : list
  +mismatch_vector(circuit) : ndarray
  +solve(circuit, tol=0.001, max_iter=50, verbose=False)
}

class Solver {
  +{static} VALID_MODES : set
  -_pf : PowerFlow
  +mode : str
  +converged : bool
  +iterations : int
  +fault_current : complex
  +fault_voltages : dict
  --
  +__init__(mode: str = "power_flow")
  +run(circuit, tol=1e-4, max_iter=50, faulted_bus_name=None, prefault_voltage=1.0, verbose=False) : Solver
  -_run_power_flow(circuit, tol, max_iter, verbose)
  -_run_fault(circuit, faulted_bus_name, prefault_voltage)
  +__repr__()
}

' Containment
Circuit "1" *-- "0..*" Bus : contains
Circuit "1" *-- "0..*" Transformer : contains
Circuit "1" *-- "0..*" TransmissionLine : contains
Circuit "1" *-- "0..*" Generator : contains
Circuit "1" *-- "0..*" Load : contains
Circuit "1" o-- "0..1" Solver : owns (after solve())

' Settings usage
Generator ..> Settings : calc_p()\n(Settings.sbase)
Load ..> Settings : calc_p/q()\n(Settings.sbase)

' Bus connectivity
Generator "1" --> "1" Bus : connects to\n(bus1_name)
Load "1" --> "1" Bus : connects to\n(bus1_name)
Transformer "1" --> "1" Bus : bus1_name
Transformer "1" --> "1" Bus : bus2_name
TransmissionLine "1" --> "1" Bus : bus1_name
TransmissionLine "1" --> "1" Bus : bus2_name

' Solver composition
Solver "1" *-- "1" PowerFlow : owns
PowerFlow "1" *-- "1" Jacobian : owns

' Dependencies
PowerFlow ..> Circuit : solve()\nmismatch_vector()\n(reads/writes buses,\nybus, injections)
Jacobian ..> Circuit : calculate_jacobian()\n(buses, ybus from\ncircuit state)
Solver ..> Circuit : run()\n(power flow or\nfault analysis)

@enduml