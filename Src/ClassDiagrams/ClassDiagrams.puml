@startuml
' ======================================================================
' Distribution Automation - Optimized Class Diagram
' Purpose: readable class layout for the Python DA power-flow simulator
' ======================================================================

title Distribution Automation Enhancement - Optimized Class Diagram

left to right direction
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam packageStyle rectangle
skinparam shadowing false
skinparam nodesep 55
skinparam ranksep 45
skinparam padding 4
skinparam ArrowColor #444444
skinparam class {
  BackgroundColor #F8FBFF
  BorderColor #2F4F6F
  FontColor #111111
  FontSize 12
}
skinparam package {
  BackgroundColor #FFFFFF
  BorderColor #666666
  FontStyle bold
}
skinparam note {
  BackgroundColor #FFF8DC
  BorderColor #AA8844
}

' ======================================================================
' Configuration and Paths
' ======================================================================

package "Configuration / Paths" as Config {
  class ProjectPaths <<module>> {
    +PROJECT_ROOT : Path
    +SRC_DIR : Path
    +DATA_DIR : Path
    +CASE1_DATA_DIR : Path
    +CASE2_DATA_DIR : Path
    --
    +ensure_directory_exists(directory) : Path
    +ensure_parent_directory_exists(file_path) : Path
  }

  class Settings {
    +{static} freq : float
    +{static} sbase : float
    --
    +__init__(freq=60.0, sbase=100.0)
  }

  class AreaScalar {
    +{static} res_scale : float
    +{static} com_scale : float
    +{static} ind_scale : float
    --
    +scale(bus_name: str) : float
  }
}

' ======================================================================
' Electrical Network Elements
' ======================================================================

package "Electrical Network Elements" as Elements {
  class Bus {
    +name : str
    +nominal_kv : float
    +bus_index : int
    +vpu : float
    +delta : float
    +bus_type : str
    +area_class : str
    +in_service : bool
    --
    +get_bus(name) : Bus
    +get_bus_index(name) : int
  }

  class Generator {
    +name : str
    +bus1_name : str
    +voltage_setpoint : float
    +mw_setpoint : float
    +x_subtransient : float
    +p : float
    --
    +calc_p() : float
  }

  class Load {
    +name : str
    +bus1_name : str
    +mw : float
    +mvar : float
    +p : float
    +q : float
    --
    +calc_p() : float
    +calc_q() : float
  }

  class Branch {
    +name : str
    +from_bus : str
    +to_bus : str
    +r : float
    +x : float
    +g : float
    +b : float
    +branch_type : str
    +status : bool
    --
    +is_closed() : bool
    +open() : void
    +close() : void
    +calc_yprim() : DataFrame
  }

  class Transformer {
    +name : str
    +bus1_name : str
    +bus2_name : str
    +r : float
    +x : float
    +tap : float
    +tap_side : str
    +status : str
    --
    +Yseries : complex
    +calc_yprim() : DataFrame
  }

  class TransmissionLine {
    +name : str
    +bus1_name : str
    +bus2_name : str
    +r : float
    +x : float
    +g : float
    +b : float
    +status : str
    --
    +Yseries : complex
    +Yshunt : complex
    +calc_yprim() : DataFrame
  }

  class CapacitorBank {
    +name : str
    +bus1_name : str
    +mvar_nominal : float
    +b_shunt_pu : float
    +status : bool
    --
    +is_closed() : bool
    +open() : void
    +close() : void
  }
}

' ======================================================================
' Core Circuit Model
' ======================================================================

package "Core Circuit Model" as Core {
  class Circuit {
    +name : str
    +buses : dict
    +branches : dict
    +transformers : dict
    +generators : dict
    +loads : dict
    +capacitor_banks : dict
    +ybus : ndarray
    +solver : Solver
    --
    +add_bus(...)
    +add_branch(...)
    +add_transformer(...)
    +add_generator(...)
    +add_load(...)
    +add_capacitor_bank(...)
    --
    +open_branch(name) : void
    +close_branch(name) : void
    +calc_ybus() : void
    +solve(mode, tol, max_iter, ...) : Solver
  }

  class PowerFlowModel <<logic>> {
    +voltage_vector_polar : list
    +voltage_vector_rectangular : ndarray
    --
    +compute_power_injection(bus, ybus, voltages) : tuple
    +compute_power_mismatch(buses, ybus, voltages) : ndarray
    +bus_angles() : ndarray
    +bus_voltages() : ndarray
  }

  class LossModel <<logic>> {
    +active_power_delivery_elements() : list
    +calc_branch_losses() : dict
    +calc_case_losses() : tuple
    +print_case_losses() : void
  }

  class FaultModel <<logic>> {
    +calc_ybus_fault() : ndarray
    +calc_zbus(ybus_fault) : ndarray
    +calc_fault_current(zbus, faulted_bus_name, prefault_voltage) : complex
    +calc_fault_voltages(zbus, faulted_bus_name, prefault_voltage) : dict
  }
}

' ======================================================================
' Distribution Automation Layer
' ======================================================================

package "Distribution Automation Layer" as DA {
  class EnergizationModel <<logic>> {
    +build_neighbor_map(closed_only=True) : dict
    +find_energized_buses() : set
    +find_deenergized_buses() : set
    +update_bus_energization() : set
    +print_energization_status() : void
  }

  class RestorationController <<logic>> {
    +find_open_boundary_switches(faulted_buses, allowed_branch_types) : list
    +evaluate_neighbor_restoration_candidate(branch_name, faulted_buses) : dict
    +auto_restore_by_neighbors(faulted_buses, allowed_branch_types) : dict
    +apply_distribution_automation(enabled, faulted_buses, allowed_branch_types) : dict
    +print_restoration_result(result) : void
  }

  note right of RestorationController
    Optional automation:
    AUTO_RESTORE = False preserves
    manual validation cases.

    AUTO_RESTORE = True searches
    open boundary tie switches,
    restores healthy buses, and
    keeps faulted_buses isolated.
  end note
}

' ======================================================================
' Newton-Raphson Solver
' ======================================================================

package "Power Flow Solver" as SolverPkg {
  class Jacobian {
    +J : ndarray
    --
    -_non_slack_buses(buses) : list
    -_pq_buses(buses) : list
    -_build_j1(...) : ndarray
    -_build_j2(...) : ndarray
    -_build_j3(...) : ndarray
    -_build_j4(...) : ndarray
    +calculate_jacobian(buses, ybus, angles, voltages) : ndarray
  }

  class PowerFlow {
    -_jac : Jacobian
    +iterations : int
    +converged : bool
    +final_mismatch_max : float
    --
    +mismatch_vector(circuit) : ndarray
    +solve(circuit, tol, max_iter, verbose) : PowerFlow
  }

  class Solver {
    +VALID_MODES : set
    +mode : str
    +converged : bool
    +iterations : int
    +fault_current : complex
    +fault_voltages : dict
    --
    +run(circuit, tol, max_iter, faulted_bus_name, prefault_voltage, verbose) : Solver
    -_run_power_flow(circuit, tol, max_iter, verbose) : void
    -_run_fault(circuit, faulted_bus_name, prefault_voltage) : void
  }
}

' ======================================================================
' File Processing / Validation
' ======================================================================

package "File Processing" as Files {
  class ExcelFileProcessor {
    +file_path : Path
    +sheet_names : list
    --
    +read_sheet(...) : DataFrame
    +read_all_sheets(...) : dict
    +export_sheet_to_json(...) : void
  }

  class Exporter <<module>> {
    +make_safe_json_file_name(sheet_name) : str
    +export_all_sheets_to_source_directory(excel_file_path, default_header_row) : void
  }

  class CompareHelp <<module>> {
    +load_powerworld_buses_json(path) : dict
    +load_powerworld_case_summary_json(path) : dict
    +load_powerworld_ybus_json(path) : tuple
    +compare_voltage_vector_polar(circuit, powerworld_buses, voltage_tolerance, angle_tolerance) : bool
    +compare_case_losses(circuit, powerworld_case_summary, mw_tolerance, mvar_tolerance) : bool
    +compare_case_summary_counts(circuit, powerworld_case_summary) : bool
    +compare_ybus(circuit, powerworld_ybus, powerworld_bus_names, tolerance) : bool
  }
}

package "Validation Scripts" as Validation {
  class FeederBuilder <<module>> {
    +build_feeder_network(case_name="Chapter14_Feeder_BaseCase") : Circuit
  }

  class BaselineTest <<script>>
  class Case1Test <<script>>
  class Case2Test <<script>>
  class Case3AutoDATest <<script>>
  class LegacyTest <<script>>
  class Main <<module>> {
    +run_test_script(script_name) : bool
    +main() : void
  }
}

' ======================================================================
' Layout anchors - keep package flow readable
' ======================================================================

Config -[hidden]right- Elements
Elements -[hidden]right- Core
Core -[hidden]right- DA
DA -[hidden]right- SolverPkg
SolverPkg -[hidden]right- Files
Files -[hidden]right- Validation

' ======================================================================
' Relationships - Configuration
' ======================================================================

Generator ..> Settings : uses sbase
Load ..> Settings : uses sbase
Load ..> AreaScalar : applies class scaling
AreaScalar ..> Bus : reads area_class

' ======================================================================
' Relationships - Circuit composition
' ======================================================================

Circuit "1" *-- "0..*" Bus : buses
Circuit "1" *-- "0..*" Branch : branches
Circuit "1" *-- "0..*" Transformer : transformers
Circuit "1" *-- "0..*" TransmissionLine : transmission_lines
Circuit "1" *-- "0..*" Generator : generators
Circuit "1" *-- "0..*" Load : loads
Circuit "1" *-- "0..*" CapacitorBank : capacitor_banks
Circuit "1" o-- "0..1" Solver : solver

' ======================================================================
' Relationships - Bus connections
' ======================================================================

Generator --> Bus : bus1_name
Load --> Bus : bus1_name
Branch --> Bus : from_bus / to_bus
Transformer --> Bus : bus1_name / bus2_name
TransmissionLine --> Bus : bus1_name / bus2_name
CapacitorBank --> Bus : bus1_name

' ======================================================================
' Relationships - Circuit model partitions
' ======================================================================

Circuit ..> PowerFlowModel : power equations
Circuit ..> LossModel : branch/case losses
Circuit ..> FaultModel : fault study
Circuit ..> EnergizationModel : source connectivity
Circuit ..> RestorationController : optional DA switching

EnergizationModel ..> Branch : closed-only graph
EnergizationModel ..> Bus : sets in_service
RestorationController ..> EnergizationModel : uses energized/de-energized sets
RestorationController ..> Branch : closes selected tie

' ======================================================================
' Relationships - Solving
' ======================================================================

Solver *-- PowerFlow : owns
PowerFlow *-- Jacobian : owns
Circuit ..> Solver : solve()
Solver ..> Circuit : run()
PowerFlow ..> Circuit : mismatch/ybus/voltage state
Jacobian ..> Circuit : buses/ybus state

' ======================================================================
' Relationships - File processing and validation
' ======================================================================

Exporter ..> ExcelFileProcessor : exports sheets
Exporter ..> ProjectPaths : uses paths
CompareHelp ..> Circuit : compares outputs
CompareHelp ..> ProjectPaths : reads JSON exports

FeederBuilder ..> Circuit : builds feeder
BaselineTest ..> FeederBuilder
Case1Test ..> FeederBuilder
Case2Test ..> FeederBuilder
Case3AutoDATest ..> FeederBuilder
LegacyTest ..> FeederBuilder

BaselineTest ..> CompareHelp
Case1Test ..> CompareHelp
Case2Test ..> CompareHelp
Case3AutoDATest ..> CompareHelp

Main ..> BaselineTest : runs
Main ..> Case1Test : runs
Main ..> Case2Test : runs
Main ..> Case3AutoDATest : runs
Main ..> LegacyTest : runs

@enduml
